<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>UIwin</AssemblyName>
    <RootNamespace>UIwin</RootNamespace>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
    <Company>ExEintel</Company>
    <Product>UIwin</Product>
    <Description>Windows GUI library for .NET applications. Create graphical interfaces without OOP.</Description>
    <NeutralLanguage>en</NeutralLanguage>
  </PropertyGroup>

</Project>
